<?xml version="1.0" encoding="utf-8" ?>
<!-- ============================================================ -->
<!--                     ChatsPage.xaml                           -->
<!-- Página para administrar chats entre usuarios                -->
<!-- ============================================================ -->
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FrontendMovil.Vistas.Chats"
             Title="Conversaciones"
             BackgroundColor="#F5F5F5">

    <Grid RowDefinitions="*, Auto">
        <ScrollView>
            <StackLayout Margin="20" Spacing="15">

                <StackLayout.Resources>
                    <!-- Paleta Neutra con vida -->
                    <Color x:Key="ButtonColor">#3759BF</Color>
                    <Color x:Key="EntryColor">#DADADA</Color>
                    <Color x:Key="TextColor">#2C3E50</Color>
                    <Color x:Key="ButtonTextColor">#FFFFFF</Color>
                    <Color x:Key="PlaceholderColor">#2C3E50</Color>

                    <Style TargetType="Button">
                        <Setter Property="FontSize" Value="14" />
                        <Setter Property="BackgroundColor" Value="{StaticResource ButtonColor}" />
                        <Setter Property="TextColor" Value="{StaticResource ButtonTextColor}" />
                        <Setter Property="CornerRadius" Value="8" />
                        <Setter Property="HeightRequest" Value="42" />
                        <Setter Property="Margin" Value="0,5" />
                    </Style>

                    <Style TargetType="Entry">
                        <Setter Property="PlaceholderColor" Value="{StaticResource PlaceholderColor}" />
                        <Setter Property="TextColor" Value="{StaticResource TextColor}"/>
                        <Setter Property="BackgroundColor" Value="{StaticResource EntryColor}"/>
                    </Style>

                    <Style x:Key="Titulo1LabelStyle" TargetType="Label">
                        <Setter Property="FontSize" Value="24" />
                        <Setter Property="FontAttributes" Value="Bold" />
                        <Setter Property="TextColor" Value="{StaticResource TextColor}" />
                    </Style>

                    <Style x:Key="Titulo2LabelStyle" TargetType="Label">
                        <Setter Property="FontSize" Value="18" />
                        <Setter Property="FontAttributes" Value="Bold" />
                        <Setter Property="TextColor" Value="{StaticResource TextColor}" />
                    </Style>

                    <Style x:Key="ParrafoLabelStyle" TargetType="Label">
                        <Setter Property="FontSize" Value="14" />
                        <Setter Property="TextColor" Value="{StaticResource TextColor}" />
                    </Style>
                </StackLayout.Resources>

                <!-- Título principal -->
                <Label Text="Conversaciones"
                       Style="{StaticResource Titulo1LabelStyle}"
                       HorizontalOptions="Center"/>

                <!-- Botón para ir al detalle de un chat -->
                <Button
                    x:Name="BTN_Chat_Detail"
                    Text="Ver Detalle"
                    Clicked="BTN_Chat_Detail_Clicked"
                    HorizontalOptions="FillAndExpand"/>

                <!-- Aquí seguiría la lista de tus chats -->
                <!-- … -->

            </StackLayout>
        </ScrollView>

        <!-- Menú inferior integrado -->
        <Grid Grid.Row="1" BackgroundColor="#FFFFFF" HeightRequest="60" Padding="10">
            <Grid.Resources>
                <Color x:Key="PrimaryColor">#FFFFFF</Color>
                <Color x:Key="TextColor">#2C3E50</Color>
                <Style TargetType="Button">
                    <Setter Property="FontSize" Value="14" />
                    <Setter Property="BackgroundColor" Value="{StaticResource PrimaryColor}" />
                    <Setter Property="TextColor" Value="{StaticResource TextColor}" />
                    <Setter Property="CornerRadius" Value="8" />
                </Style>
            </Grid.Resources>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" x:Name="BTN_Main" Text="Inicio" Clicked="BTN_Main_Clicked"/>
            <Button Grid.Column="1" x:Name="BTN_Buscar" Text="Buscar" Clicked="BTN_Buscar_Clicked"/>
            <Button Grid.Column="2" x:Name="BTN_IngresarProducto" Text="Ingresar Producto" Clicked="BTN_IngresarProducto_Clicked"/>
            <Button Grid.Column="3" x:Name="BTN_Chats" Text="Chats" Clicked="BTN_Chats_Clicked"/>
            <Button Grid.Column="4" x:Name="BTN_Cuenta" Text="Cuenta" Clicked="BTN_Cuenta_Clicked"/>
        </Grid>
    </Grid>
</ContentPage>
