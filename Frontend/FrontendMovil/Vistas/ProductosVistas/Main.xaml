<?xml version="1.0" encoding="utf-8" ?>
<!-- ============================================================ -->
<!--                   PrincipalPage.xaml                         -->
<!-- Página que muestra productos destacados y un mapa           -->
<!-- ============================================================ -->
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:converters="clr-namespace:FrontendMovil.Utilitarios"
             xmlns:maps="clr-namespace:Microsoft.Maui.Controls.Maps;assembly=Microsoft.Maui.Controls.Maps"
             x:Class="FrontendMovil.Vistas.Main"
             Title="Inicio"
             BackgroundColor="#F5F5F5">

    <Grid RowDefinitions="*, Auto">
        <!-- Contenido principal scrollable -->
        <ScrollView Grid.Row="0">
            <StackLayout Margin="20" Spacing="20">

                <StackLayout.Resources>
                    <!-- Paleta Neutra con vida -->

                    <Color x:Key="ButtonColor">#3759BF</Color>
                    <!-- Botones y destacados -->
                    <Color x:Key="EntryColor">#DADADA</Color>
                    <!-- Botones y destacados -->
                    <Color x:Key="TextColor">#2C3E50</Color>
                    <!-- Texto principal -->
                    <Color x:Key="ButtonTextColor">#FFFFFF</Color>
                    <!-- Texto sobre botones -->
                    <Color x:Key="PlaceholderColor">#2C3E50</Color>
                    <!-- Placeholder (puede ajustarse) -->

                    <!-- BTN -->
                    <Style TargetType="Button">
                        <Setter Property="FontSize" Value="14" />
                        <Setter Property="BackgroundColor" Value="{StaticResource ButtonColor}" />
                        <Setter Property="TextColor" Value="{StaticResource ButtonTextColor}" />
                        <Setter Property="CornerRadius" Value="8" />
                    </Style>

                    <!-- TXT -->
                    <Style TargetType="Entry">
                        <Setter Property="PlaceholderColor" Value="{StaticResource PlaceholderColor}" />
                        <Setter Property="TextColor" Value="{StaticResource TextColor}"/>
                        <Setter Property="BackgroundColor" Value="{StaticResource EntryColor}"/>
                    </Style>

                    <!-- LBL Título 1 -->
                    <Style x:Key="Titulo1LabelStyle" TargetType="Label">
                        <Setter Property="FontSize" Value="24" />
                        <Setter Property="FontAttributes" Value="Bold" />
                        <Setter Property="TextColor" Value="{StaticResource TextColor}" />
                    </Style>

                    <!-- LBL Título 2 -->
                    <Style x:Key="Titulo2LabelStyle" TargetType="Label">
                        <Setter Property="FontSize" Value="18" />
                        <Setter Property="FontAttributes" Value="Bold" />
                        <Setter Property="TextColor" Value="{StaticResource TextColor}" />
                    </Style>

                    <!-- LBL Párrafo -->
                    <Style x:Key="ParrafoLabelStyle" TargetType="Label">
                        <Setter Property="FontSize" Value="14" />
                        <Setter Property="TextColor" Value="{StaticResource TextColor}" />
                    </Style>
                    <!-- Converter -->
                    <converters:ByteArrayToImageSourceConverter x:Key="ByteArrayToImageSourceConverter" />
                </StackLayout.Resources>

                <!-- Título superior -->
                <Label Text="ShareX" 
                       HorizontalOptions="Center"
                       Style="{StaticResource Titulo1LabelStyle}"/>

                <!-- Primera lista de productos -->
                <Label Text="Productos" 
                       Style="{StaticResource Titulo1LabelStyle}"/>

                <Label x:Name="TXT_Mensaje" 
                       Style="{StaticResource ParrafoLabelStyle}"/>

                <!--Template-->
                <CollectionView x:Name="CollectionViewProductos" ItemsSource="{Binding ListaProductos}" 
                                ItemsLayout="HorizontalList">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Frame BackgroundColor="#DADADA"
                                   CornerRadius="10"
                                   Padding="10"
                                   WidthRequest="220"
                                   MinimumHeightRequest="300"
                                   Margin="5">
                                <StackLayout Spacing="5">
                                    <Image Source="{Binding Imagen, Converter={StaticResource ByteArrayToImageSourceConverter}}"
                                           MinimumHeightRequest="100"
                                           Aspect="AspectFill"/>

                                    <Label Text="{Binding Nombre}"
                                           FontSize="14"
                                           TextColor="#2C3E50"
                                           HorizontalOptions="Center" />

                                    <Label Text="{Binding Precio, StringFormat='Precio: ₡{0:N0}'}"
                                           FontSize="12"
                                           TextColor="#2C3E50"/>

                                    <Label Text="{Binding PrecioAlquiler, StringFormat='Alquiler: ₡{0:N0}'}"
                                           FontSize="12"
                                           TextColor="#2C3E50"/>

                                    <Label Text="{Binding CalificacionPromedio, StringFormat='★ {0:N1}'}"
                                           FontSize="12"
                                           TextColor="#D4B45A" />

                                    <Button x:Name="BTN_VerProducto"  
                                            Text="Ver producto"
                                            FontSize="12"
                                            BackgroundColor="#3759BF"
                                            TextColor="White"
                                            Clicked="BTN_VerProducto_Clicked"
                                            VerticalOptions="End"/>
                                </StackLayout>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <!--Boton-->
                <Button x:Name="BTN_Productos" 
                        Text="Ver más productos"
                        Clicked="BTN_Productos_Clicked"/>

                <!-- Segunda lista de productos -->
                <Label Text="Productos Recomendados" 
                       Style="{StaticResource Titulo1LabelStyle}"/>

                <Label x:Name="TXT_MensajeRecomendado" 
                       Style="{StaticResource ParrafoLabelStyle}"/>

                <!--Template-->
                <CollectionView x:Name="CollectionViewProductosRecomendados" 
                                ItemsSource="{Binding ListaProductosRecomendados}" 
                                ItemsLayout="HorizontalList">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Frame BackgroundColor="#DADADA"
                                   CornerRadius="10"
                                   Padding="10"
                                   WidthRequest="220"
                                   MinimumHeightRequest="300"
                                   Margin="5">
                                <StackLayout Spacing="5">
                                    <Image Source="{Binding Imagen, Converter={StaticResource ByteArrayToImageSourceConverter}}"
                                           MinimumHeightRequest="100"
                                           Aspect="AspectFill"/>

                                    <Label Text="{Binding Nombre}"
                                           FontSize="14"
                                           TextColor="#2C3E50"
                                           HorizontalOptions="Center" />

                                    <Label Text="{Binding Precio, StringFormat='Precio: ₡{0:N0}'}"
                                           FontSize="12"
                                           TextColor="#2C3E50"/>

                                    <Label Text="{Binding PrecioAlquiler, StringFormat='Alquiler: ₡{0:N0}'}"
                                           FontSize="12"
                                           TextColor="#2C3E50"/>

                                    <Label Text="{Binding CalificacionPromedio, StringFormat='★ {0:N1}'}"
                                           FontSize="12"
                                           TextColor="#D4B45A" />

                                    <Button x:Name="BTN_VerProducto" 
                                            Text="Ver producto"
                                            FontSize="12"
                                            BackgroundColor="#3759BF"
                                            TextColor="White"
                                            Clicked="BTN_VerProducto_Clicked"
                                            VerticalOptions="End"/>
                                </StackLayout>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <!--Boton-->
                <Button x:Name="BTN_ProductosRecomendados" 
                        Text="Ver más productos recomendados"
                        Clicked="BTN_ProductosRecomendados_Clicked"/>

                <!-- Distancia + Botón -->
                <Label Text="Mapa Vendedores" 
                       Style="{StaticResource Titulo1LabelStyle}"/>

                <Label Text="Si quieres saber cuales vendedores estan cerca tuyo, ingresa la distancia de la cual queires saber quienes estan cerca" 
                       Style="{StaticResource ParrafoLabelStyle}"/>

                <Entry x:Name="TXT_Distancia" 
                       Placeholder="Ingrese distancia (km)" 
                       Keyboard="Numeric"/>
                
                <Button x:Name="BTN_MapaVendedores" 
                        Text="Buscar vendedores"
                        Clicked="BTN_MapaVendedores_Clicked"/>

                <!-- Mapa -->

                
            </StackLayout>
        </ScrollView>

        <!-- Menú inferior integrado -->
        <Grid Grid.Row="1" BackgroundColor="#FFFFFF" HeightRequest="60" Padding="10">
            <Grid.Resources>
                <Color x:Key="PrimaryColor">#FFFFFF</Color>
                <Color x:Key="TextColor">#2C3E50</Color>
                <Style TargetType="Button">
                    <Setter Property="FontSize" Value="14" />
                    <Setter Property="BackgroundColor" Value="{StaticResource PrimaryColor}" />
                    <Setter Property="TextColor" Value="{StaticResource TextColor}" />
                    <Setter Property="CornerRadius" Value="8" />
                </Style>
            </Grid.Resources>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackLayout Grid.Column="0" HorizontalOptions="Center" VerticalOptions="Center">
                <Button x:Name="BTN_Main" Text="Inicio" Clicked="BTN_Main_Clicked"/>
            </StackLayout>

            <StackLayout Grid.Column="1" HorizontalOptions="Center" VerticalOptions="Center">
                <Button x:Name="BTN_Buscar" Text="Buscar" Clicked="BTN_Buscar_Clicked"/>
            </StackLayout>

            <StackLayout Grid.Column="2" HorizontalOptions="Center" VerticalOptions="Center">
                <Button x:Name="BTN_IngresarProducto" Text="Ingresar Producto" Clicked="BTN_IngresarProducto_Clicked"/>
            </StackLayout>

            <StackLayout Grid.Column="3" HorizontalOptions="Center" VerticalOptions="Center">
                <Button x:Name="BTN_Chats" Text="Chats" Clicked="BTN_Chats_Clicked"/>
            </StackLayout>

            <StackLayout Grid.Column="4" HorizontalOptions="Center" VerticalOptions="Center">
                <Button x:Name="BTN_Cuenta" Text="Cuenta" Clicked="BTN_Cuenta_Clicked"/>
            </StackLayout>
        </Grid>
    </Grid>
</ContentPage>